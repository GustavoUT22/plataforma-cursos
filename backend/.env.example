# Puerto donde corre la API
PORT=3000

# Cadena de conexión a MongoDB Atlas (NO subir la real)
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/gestion_cursos
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/gestion_cursos

# Clave secreta para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_una_clave_larga_y_segura

# Orígenes permitidos por CORS (URLs de los frontends, separados por coma)
# Ej. producción: https://admin.vercel.app,https://portal.vercel.app,https://landing.vercel.app
CORS_ORIGINS=http://localhost:4200,http://localhost:5173,http://localhost:3000
